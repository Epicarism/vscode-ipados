                AIModel(id: "mistral-large-latest", name: "Mistral Large", provider: .mistral),
                AIModel(id: "pixtral-large-latest", name: "Pixtral Large", provider: .mistral),
                AIModel(id: "codestral-latest", name: "Codestral", provider: .mistral),
